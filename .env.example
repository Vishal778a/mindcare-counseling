# ===========================================
# MindCare — Environment Configuration
# ===========================================
# Copy this file as .env and fill in your values
# Restart the dev server after changes

# --- Google OAuth 2.0 ---
# Get this from Google Cloud Console > APIs & Services > Credentials > OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Admin Email ---
# The Google account email that should be recognized as the Counsellor (admin)
# When this email logs in via Google, they get admin access
VITE_ADMIN_EMAIL=your-email@gmail.com
